{% extends 'base.html.j2' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <div class="container grid-xl py-2">
        {# Implicit submit for Enter. Must be the FIRST submit button in tree order
           anywhere in the document so the browser uses it for forms submitted via
           Enter inside a text input. The visible Next/Previous/Save buttons and the
           steps page-jump buttons are all attached to the form via the `form`
           attribute and would otherwise win the tree-order race. #}
        <button type="submit" form="checklist_form" name="submit_action" value="Next"
                tabindex="-1" aria-hidden="true" class="clf-visually-hidden">Next</button>

        <h2 class="clf-checklist-title">{{ title }}</h2>

        <div class="clf-meta-row text-gray">
            {% if version %}
                <span class="clf-version tooltip tooltip-bottom" data-tooltip="Template version (format: YYYYMMDDNN)">
                    Version: {{ version }}
                </span>
            {% endif %}
            <span class="clf-required-hint" aria-hidden="true">Required tasks are marked red.</span>
        </div>

        {% include 'steps.html.j2' %}

        <h3 class="clf-page-title">{{ pages[page_id].title }}</h3>

        <form id="checklist_form" method="post" onsubmit="window.removeEventListener('beforeunload', handleBeforeUnload);">
            {% block form_content %}
            {% endblock %}
        </form>

        {% include 'navigation_bar.html.j2' %}
    </div>

    <script>
        /* Script to detect unsaved/local changes to the form and warn the user before navigating away. */

        function saveFormValues(form) {
            Array.from(form).forEach(element => {
                if (['INPUT', 'SELECT', 'TEXTAREA'].includes(element.tagName)) {
                    if (['checkbox', 'radio'].includes(element.type)) {
                        element.dataset.clfChecked = element.checked;
                    } else {
                        element.dataset.clfValue = element.value;
                    }
                }
            });
        }

        function formChanged(form) {
            return Array.from(form).some((element) => {
                if (['INPUT', 'SELECT', 'TEXTAREA'].includes(element.tagName)) {
                    if (['checkbox', 'radio'].includes(element.type)) {
                        return element.dataset.clfChecked !== element.checked;
                    }

                    return element.dataset.clfValue !== element.value;
                }

                return false;
            });
        }

        function handleBeforeUnload(event) {
            if (formChanged(form)) {
                event.preventDefault();
            }
        }

        const form = document.getElementById('checklist_form');

        window.addEventListener('DOMContentLoaded', () => {
            saveFormValues(form);
        });
    </script>
    <script>
        /* Script to inject copy functionality into code block copy buttons. */

        /**
         * Reconstruct the original code text from clf-code-line spans.
         *
         * Each logical line of a code block is wrapped in a
         * <span class="clf-code-line"> for line-wrap styling. Empty code
         * lines produce empty spans, and the browser's innerText algorithm
         * silently drops empty display:block elements, losing blank lines.
         * This function reads each span's textContent individually and
         * joins them with newlines to preserve the original whitespace.
         *
         * Falls back to innerText for code blocks without clf-code-line
         * spans (e.g. from other renderers).
         */
        function getCodeText(codeElement) {
            const lines = codeElement.querySelectorAll('.clf-code-line');
            if (lines.length === 0) {
                return codeElement.innerText;
            }
            return Array.from(lines).map((line) => line.textContent).join('\n');
        }

        async function copyCode(sender) {
            const code = sender.parentElement.querySelector('code');

            navigator.clipboard.writeText(getCodeText(code)).then(() => {
                sender.textContent = 'Copied!';

                setTimeout(() => {
                    sender.textContent = 'Copy';
                }, 1200);
            }).catch((error) => {
                console.error('Failed to copy code: ', error);
            });

        }

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.clf-code-copy-btn').forEach(
                (btn) => {
                    btn.addEventListener('click', (event) => {
                        event.preventDefault(); // Do not navigate or submit a form when clicking this button.
                        copyCode(btn);
                    });
                },
            );
        });

        /*
         * Override native copy (Ctrl+C) within code blocks to preserve
         * empty lines (same problem as described in getCodeText).
         *
         * Only intercepts multi-line selections so that copying a partial
         * text selection within a single line still uses default browser
         * behavior.
         */
        document.addEventListener('copy', (event) => {
            const selection = window.getSelection();
            if (!selection.rangeCount) {
                return;
            }

            const range = selection.getRangeAt(0);
            const ancestor = range.commonAncestorContainer;
            const codeBlock = ancestor.nodeType === Node.ELEMENT_NODE
                ? ancestor.closest('.code code')
                : ancestor.parentElement?.closest('.code code');

            if (!codeBlock) {
                return;
            }

            const lines = Array.from(codeBlock.querySelectorAll('.clf-code-line'));
            if (lines.length === 0) {
                return;
            }

            const selectedLines = lines.filter((line) => range.intersectsNode(line));
            if (selectedLines.length <= 1) {
                return;
            }

            event.clipboardData.setData('text/plain', selectedLines.map((line) => line.textContent).join('\n'));
            event.preventDefault();
        });
    </script>
    <script>
        /* Detect wrapped code lines and add a class for the wrap indicator icon. */

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.clf-code-line').forEach((line) => {
                const lineHeight = parseFloat(getComputedStyle(line).lineHeight);
                line.classList.toggle('clf-wrapped', line.getBoundingClientRect().height > lineHeight * 1.1);
            });
        });
    </script>
    <script>
        /* Pressing Enter outside any input field also triggers Next. The browser
           only does this implicitly when an input has focus; we extend the
           behavior to the whole page by clicking the off-screen default submit. */

        document.addEventListener('keydown', (event) => {
            if (event.key !== 'Enter') return;

            const target = event.target;
            const tag = target.tagName;

            /* Let the browser handle the natural cases:
               - INPUT (text/number/etc): browser already submits via the default button
               - TEXTAREA: Enter inserts a newline
               - BUTTON / A / SELECT: Enter activates the focused control
               - contenteditable: Enter inserts a newline */
            if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'BUTTON' || tag === 'A' || tag === 'SELECT') {
                return;
            }
            if (target.isContentEditable) return;

            /* Outside any actionable element: trigger the implicit default submit. */
            const defaultBtn = document.querySelector(
                'button[type="submit"][form="checklist_form"][value="Next"]'
            );
            if (defaultBtn) {
                event.preventDefault();
                defaultBtn.click();
            }
        });
    </script>
    <script>
        /* Wire up the "Run" buttons rendered by linuxfabrik.clf.run_template. */

        async function launchSubChecklist(path, button) {
            try {
                const response = await fetch('/run', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({path: path}),
                });

                if (!response.ok) {
                    alert('Failed to launch checklist.');
                    return;
                }

                const data = await response.json();
                window.open(data.url, '_blank');
            } catch (error) {
                alert('Failed to launch checklist: ' + error.message);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[data-action="run-template"]').forEach((btn) => {
                btn.addEventListener('click', (event) => {
                    /* Do not submit the surrounding checklist form. */
                    event.preventDefault();
                    launchSubChecklist(btn.dataset.path, btn);
                });
            });
        });
    </script>
    <script>
        /* Heartbeat script to show an error message if disconnected from the server. */

        async function checkHeartBeat(url, server_id) {
            try {
                const request = new Request(
                    url + '/heartbeat',
                    {
                        method: 'GET',
                        headers: {'Accept': 'application/json'},
                        mode: 'same-origin',
                    },
                );

                const response = await fetch(request);

                if (!response.ok) {
                    return false;
                }

                const data = await response.json()

                return data.server_id === server_id;
            } catch (error) {
                return false;
            }
        }

        const server_id = '{{ server_id }}';

        window.addEventListener('beforeunload', handleBeforeUnload);

        const heartbeatInterval = setInterval(
            () => {
                checkHeartBeat(window.location.origin, server_id).then(
                    (server_alive) => {
                        if (!server_alive) {
                            const warning_toast = document.createElement('div');
                            warning_toast.classList.add('my-2', 'toast', 'toast-error');
                            warning_toast.textContent = 'The server has shut down. Some of your changes might not have been saved.';

                            form.parentNode.prepend(warning_toast);
                            clearInterval(heartbeatInterval);
                        }
                    }
                );
            },
            1000,
        )
    </script>
{% endblock %}

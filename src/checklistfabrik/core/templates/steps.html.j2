{% if pages|length > 1 %}
<nav class="clf-toc" aria-label="Checklist pages">
    <ol>
        {% for page in pages %}
            {% set state = 'active' if page.id == page_id
                           else 'skipped' if not page.eval_when
                           else 'completed' if page.id < page_id
                           else 'upcoming' %}
            <li class="clf-toc-item clf-toc-{{ state }}">
                {# Buttons (not links) so the page-jump submits the checklist form. #}
                <button class="clf-toc-link tooltip tooltip-right clf-tooltip-wide"
                        data-tooltip="{% if state == 'active' %}Step {{ page.id + 1 }} of {{ pages | length }} (current){% elif state == 'skipped' %}Skipped — condition not met{% else %}Jump here (no validation){% endif %}"
                        {% if state == 'skipped' %}disabled{% endif %}
                        form="checklist_form"
                        formnovalidate="formnovalidate"
                        name="submit_action"
                        type="submit"
                        value="Page {{ page.id }}">{{ page.title }}</button>
            </li>
        {% endfor %}
    </ol>
</nav>
{% endif %}

{% if pages|length > 1 %}
<div style="margin-block: 1.2rem;">
    <ul class="step">
        {% for page in pages %}
            <li class="step-item {%- if page.id == page_id %} active {%- elif page.id < page_id and not page.eval_when %} skipped {%- endif %}">
                {# Buttons (not inputs) so Spectre's pseudo-element step markers render correctly. #}
                <button class="tooltip {% if page.id == page_id %}tooltip-bottom{% endif %}"
                        data-tooltip="{% if page.id == page_id %}Step {{ page.id + 1 }} of {{ pages | length }} (current){% elif page.id < page_id and not page.eval_when %}Skipped — condition not met{% else %}Jump here (no validation){% endif %}"
                        form="checklist_form"
                        formnovalidate="formnovalidate"
                        name="submit_action"
                        type="submit"
                        value="Page {{ page.id }}">{{ page.title }}</button>
            </li>
        {% endfor %}
    </ul>
</div>
{% endif %}

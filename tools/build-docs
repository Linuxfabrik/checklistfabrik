"""Generates the docs/ directory structure with symlinks and the mkdocs.yml navigation
for the Linuxfabrik ChecklistFabrik documentation site.

The site's landing page (docs/index.md) is a symlink to the root README.md so the
docs site and GitHub always show the same front page. CHANGELOG / CODE_OF_CONDUCT /
CONTRIBUTING / SECURITY are symlinked into docs/ as well; user_guide.md already
lives in docs/.

A second symlink under docs/docs/user_guide.md points back to docs/user_guide.md so
relative links in README.md like `[User Guide](docs/user_guide.md)` resolve both on
GitHub and on the rendered mkdocs site.

Run this tool from the repository root directory.
"""

import os
import sys

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026043001'

REPO_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), '..'))
DOCS_DIR = os.path.join(REPO_ROOT, 'docs')

# Top-level markdown files to include in the documentation.
# Format: (source filename, target filename in docs/, nav title or None for hidden).
TOP_LEVEL_DOCS = [
    ('CHANGELOG.md', 'CHANGELOG.md', None),
    ('CODE_OF_CONDUCT.md', 'CODE_OF_CONDUCT.md', None),
    ('CONTRIBUTING.md', 'contributing.md', 'Contributing'),
    ('README.md', 'index.md', 'Home'),
    ('SECURITY.md', 'security.md', 'Security'),
]

# Pages that already live in docs/ and should appear in the nav under the given
# title. These are not symlinked (they are real files maintained in docs/).
NATIVE_DOCS = [
    ('user_guide.md', 'User Guide'),
]

# Aliases that mirror the repo-relative path inside docs/ so that links written
# as `docs/<file>` in README.md resolve correctly on the rendered site.
# Format: (target path under docs/, source path relative to repo root).
LINK_ALIASES = [
    ('docs/user_guide.md', 'docs/user_guide.md'),
]


def create_symlink(source, target):
    """Create a relative symlink from target to source."""
    target_dir = os.path.dirname(target)
    os.makedirs(target_dir, exist_ok=True)
    rel_source = os.path.relpath(source, target_dir)
    if os.path.islink(target) or os.path.exists(target):
        os.unlink(target)
    os.symlink(rel_source, target)


def generate_mkdocs_yml():
    """Generate the mkdocs.yml content."""
    lines = []
    lines.append('# This file is auto-generated by tools/build-docs. Do not edit manually.')
    lines.append('')
    lines.append("site_name: 'Linuxfabrik ChecklistFabrik'")
    lines.append("site_url: 'https://linuxfabrik.github.io/checklistfabrik/'")
    lines.append("repo_url: 'https://github.com/Linuxfabrik/checklistfabrik'")
    lines.append("repo_name: 'Linuxfabrik/checklistfabrik'")
    lines.append('')
    lines.append('theme:')
    lines.append("  name: 'material'")
    lines.append('  icon:')
    lines.append("    logo: 'material/clipboard-check-outline'")
    lines.append('  palette:')
    lines.append("    - scheme: 'default'")
    lines.append("      primary: 'blue grey'")
    lines.append("      accent: 'orange'")
    lines.append('      toggle:')
    lines.append("        icon: 'material/brightness-7'")
    lines.append("        name: 'Switch to dark mode'")
    lines.append("    - scheme: 'slate'")
    lines.append("      primary: 'blue grey'")
    lines.append("      accent: 'orange'")
    lines.append('      toggle:')
    lines.append("        icon: 'material/brightness-4'")
    lines.append("        name: 'Switch to light mode'")
    lines.append('  features:')
    lines.append('    - content.code.copy')
    lines.append('    - navigation.expand')
    lines.append('    - navigation.instant')
    lines.append('    - navigation.sections')
    lines.append('    - navigation.top')
    lines.append('    - search.highlight')
    lines.append('    - search.suggest')
    lines.append('    - toc.follow')
    lines.append('')
    lines.append('markdown_extensions:')
    lines.append('  - admonition')
    lines.append('  - attr_list')
    lines.append('  - def_list')
    # md_in_html lets python-markdown process Markdown syntax inside HTML
    # blocks, which the README's `<div align="center" markdown="1">…</div>`
    # block needs so the inline `![…](…)` shields.io image links render as
    # actual badges instead of raw text.
    lines.append('  - md_in_html')
    lines.append('  - tables')
    lines.append('  - toc:')
    lines.append('      permalink: true')
    lines.append('')
    lines.append('plugins:')
    lines.append('  - search')
    lines.append('')
    lines.append('validation:')
    lines.append('  links:')
    lines.append("    not_found: 'info'")
    lines.append('')
    lines.append('not_in_nav: |')
    lines.append('  CHANGELOG.md')
    lines.append('  CODE_OF_CONDUCT.md')
    # The docs/<file> aliases shadow the top-level pages on the rendered site
    # purely so README links resolve; do not list them in the navigation.
    for target, _ in LINK_ALIASES:
        lines.append(f'  {target}')
    lines.append('')

    lines.append('nav:')
    lines.append("  - 'Home': 'index.md'")
    for native_target, native_title in NATIVE_DOCS:
        lines.append(f"  - '{native_title}': '{native_target}'")
    for _, target_name, nav_title in TOP_LEVEL_DOCS:
        if not nav_title or target_name == 'index.md':
            continue
        lines.append(f"  - '{nav_title}': '{target_name}'")
    lines.append('')

    return '\n'.join(lines)


def main():
    os.makedirs(DOCS_DIR, exist_ok=True)

    # Top-level docs: symlink from repo root into docs/.
    for source_name, target_name, _ in TOP_LEVEL_DOCS:
        source = os.path.join(REPO_ROOT, source_name)
        target = os.path.join(DOCS_DIR, target_name)
        if not os.path.isfile(source):
            print(f'WARNING: {source_name} not found, skipping.')
            continue
        create_symlink(source, target)

    # Link aliases: same file reachable under its repo-relative path on the site.
    for target_rel, source_rel in LINK_ALIASES:
        source = os.path.join(REPO_ROOT, source_rel)
        target = os.path.join(DOCS_DIR, target_rel)
        if not os.path.isfile(source):
            print(f'WARNING: {source_rel} not found, skipping alias.')
            continue
        create_symlink(source, target)

    # Generate mkdocs.yml.
    mkdocs_path = os.path.join(REPO_ROOT, 'mkdocs.yml')
    with open(mkdocs_path, 'w', encoding='utf-8') as fh:
        fh.write(generate_mkdocs_yml())

    print(f'Created {len(TOP_LEVEL_DOCS) + len(LINK_ALIASES)} symlinks in docs/')
    print('Generated mkdocs.yml')

    return 0


if __name__ == '__main__':
    sys.exit(main())
